<idea-plugin>
    <id>com.yot.wor</id>
    <name>World Of Refactoring</name>
    <vendor>yot</vendor>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow factoryClass="com.yot.wor.toolWindow.WorToolWindowFactory"
                    id="World Of Refactoring"
                    anchor="right"
                    icon="com.yot.wor.Icons.TOOL_WINDOW"/>
        <notificationGroup id="WoR Notifications"
                           displayType="BALLOON"
                           isLogByDefault="false"/>
        <applicationService serviceImplementation="com.yot.wor.services.PlayerStateService"/>
        <applicationService serviceImplementation="com.yot.wor.services.QuestService"/>
        <projectService serviceImplementation="com.yot.wor.services.RefactoringDetectionService"/>
        <projectService serviceImplementation="com.yot.wor.settings.WoRSettings"/>
    </extensions>

    <applicationListeners>
        <listener class="com.yot.wor.listeners.RefactoringAnActionListener"
                  topic="com.intellij.openapi.actionSystem.ex.AnActionListener"/>
    </applicationListeners>
</idea-plugin>
